# Database
DATABASE_URL="postgresql://username:password@localhost:5432/main_project?schema=public"

# JWT Secret (generate a secure random string)
JWT_SECRET="your-secure-jwt-secret-here"

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/google/callback"

# Session Secret for Passport (generate a secure random string)
SESSION_SECRET="your-secure-session-secret-here"

# Server Port
PORT=3000

# Mail configuration
# MAIL_DRIVER decides how mail is sent: 'smtp' (default), 'console' (no-op), 'ses-smtp' (use AWS SES via SMTP credentials)
# If you're using AWS SES SMTP, set SMTP_HOST to the regional SMTP endpoint (e.g. email-smtp.us-west-2.amazonaws.com)
MAIL_DRIVER=smtp
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=no-reply@example.com
APP_BASE_URL=http://localhost:3000
SEND_WELCOME_EMAILS=false